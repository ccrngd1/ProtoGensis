# Memory Agent Bedrock Configuration
# Copy this file to .env and customize as needed

# ==========================================
# Core Settings
# ==========================================
MEMORY_DB_PATH=memory.db

# ==========================================
# Consolidation Settings
# ==========================================
# Background check interval (seconds) - how often to check if consolidation should run
CONSOLIDATION_INTERVAL=300

# Minimum memories needed to trigger regular consolidation
MIN_MEMORIES_CONSOLIDATE=5

# Force consolidation after this many seconds (even if below MIN_MEMORIES_CONSOLIDATE)
DAILY_CONSOLIDATION_INTERVAL=86400

# Run consolidation at startup if unconsolidated memories exist
ENABLE_STARTUP_CONSOLIDATION=true

# Enable daily forced consolidation
ENABLE_DAILY_CONSOLIDATION=true

# ==========================================
# AWS Bedrock Settings
# ==========================================
# Bedrock model ID (uses cross-region inference profile)
BEDROCK_MODEL_ID=amazon-bedrock/us.anthropic.claude-haiku-4-5-20251001-v1:0

# AWS Region for Bedrock
AWS_REGION=us-east-1

# AWS Credentials (optional - will use IAM role or default credentials if not set)
# AWS_ACCESS_KEY_ID=your_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_here

# ==========================================
# File Watcher Settings
# ==========================================
# Enable automatic file ingestion
ENABLE_FILE_WATCHER=true

# Directory to watch for new files
WATCH_DIR=./inbox

# Quick scan interval for new files (seconds)
WATCH_POLL_INTERVAL=60

# Full scan interval for change detection (seconds)
WATCH_CHANGE_DETECTION_INTERVAL=1800

# Scan subdirectories recursively
WATCH_RECURSIVE=false

# Track and re-ingest modified files
WATCH_TRACK_CHANGES=true

# Comma-separated list of directories to ignore
WATCH_IGNORE_DIRS=.obsidian,.git,node_modules,.venv,__pycache__,.kiro,.claude
