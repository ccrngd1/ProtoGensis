# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# Bedrock Configuration
BEDROCK_KB_ID=your-knowledge-base-id-here
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514

# SageMaker Endpoints (optional - for real AWS deployment)
SAGEMAKER_NLI_ENDPOINT=nli-deberta-v3-large
SAGEMAKER_ENCODER_ENDPOINT=fast-faithful-verifier

# Mock Mode (set to true for local testing without AWS)
MOCK_MODE=true

# Cost Estimation (per 1K tokens)
CLAUDE_INPUT_COST_PER_1K=0.003
CLAUDE_OUTPUT_COST_PER_1K=0.015
SAGEMAKER_COMPUTE_COST_PER_SEC=0.000392  # ~$1.41/hr for ml.g5.xlarge
